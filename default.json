{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    ":dependencyDashboard",
    ":automergePr",
    ":disableRateLimiting",
    ":enablePreCommit",
    "helpers:pinGitHubActionDigests",
    "github>home-operations/renovate-presets//policies/semanticCommits.json5#2.0.0",
    "github>home-operations/renovate-presets//managers/annotated.json5#2.0.0",
    "local>bjw-s/renovate-config:pr-labels"
  ],
  "timezone": "Europe/Amsterdam",
  "dependencyDashboardTitle": "Renovate Dashboard",
  "suppressNotifications": [
    "prEditedNotification",
    "prIgnoreNotification"
  ],
  "commitBodyTable": true,
  "rebaseWhen": "auto",
  "renovate-config": {
    "managerFilePatterns": [
      "/\\.renovate\\/.*\\.json5?$/"
    ]
  }
}
